# Create a Spotify app at https://developer.spotify.com/dashboard
# Add http://localhost:5173/callback as a Redirect URI
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Optional: enable full Apple Music catalog export (not limited to local Music library)
# Generate a developer token in Apple Music API portal and provide a Music user token.
APPLE_MUSIC_DEVELOPER_TOKEN=
APPLE_MUSIC_USER_TOKEN=
APPLE_MUSIC_STOREFRONT=fr
